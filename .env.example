# PostgreSQL
DATABASE_URL="postgres://user:password@localhost:5432/reviewpilot"

# Auth.js – Secret erzeugen mit: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# Oeffentliche Basis-URL (fuer QR-Codes, E-Mail-Links, Opt-out)
APP_URL="http://localhost:3000"

# SMTP-Fallback (kann pro Organisation in den Einstellungen ueberschrieben werden)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ReviewPilot <noreply@example.com>"

# Storage: "local" (MVP) oder "minio" (selbst gehostet, S3-kompatibel)
STORAGE_DRIVER="local"
LOCAL_STORAGE_DIR="./storage"

# MinIO – nur bei STORAGE_DRIVER="minio" noetig
# Achtung: Port 9001 ist die Web-Konsole, die S3-API laeuft i.d.R. auf 9000
S3_ENDPOINT=""
S3_PORT="9000"
S3_USE_SSL="false"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="reviewpilot"
